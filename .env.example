# ============================================
# VIXXER MENSAJERO - MOBILE
# Variables de entorno del cliente
# ============================================
# 1. Copia este archivo a .env (sin el .example)
# 2. Llena los valores reales
# 3. NUNCA subas el archivo .env real al repo
# 4. Si agregas variables nuevas, actualiza este .example
# ============================================

# ---------- Backend ----------
# URL del backend de Vixxer Mensajero
#
# Si pruebas contra un backend LOCAL:
#   - En emulador Android: http://10.0.2.2:3000
#   - En celular fisico: usa la IP LAN de tu laptop
#     Ejemplo: http://192.168.1.100:3000
#     (Encuentra tu IP con `ipconfig` en Windows o `ifconfig` en Mac/Linux)
#
# Si pruebas contra el backend DESPLEGADO:
#   - https://vixxer-mensajero-backend.up.railway.app
EXPO_PUBLIC_API_URL=http://localhost:3000

# ---------- Socket.IO ----------
# URL del servidor Socket.IO (usualmente la misma que API_URL)
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000

# ---------- Entorno ----------
# Valores: development | staging | production
EXPO_PUBLIC_ENV=development

# ---------- Feature flags (post-MVP) ----------
# Activar/desactivar features en desarrollo
# EXPO_PUBLIC_FEATURE_BLE=false
# EXPO_PUBLIC_FEATURE_GATEWAY=false
