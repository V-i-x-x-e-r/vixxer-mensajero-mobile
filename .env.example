# ============================================
# VIXXER MENSAJERO - MOBILE
# Variables de entorno del cliente
# ============================================
# 1. Copia este archivo a .env (sin el .example)
# 2. Llena los valores reales
# 3. NUNCA subas el archivo .env real al repo
# 4. Si agregas variables nuevas, actualiza este .example
# 5. Tras cambiar el .env reinicia Expo:  npx expo start --clear
# ============================================

# ---------- Backend (FastAPI + Socket.IO) ----------
# El backend de Vixxer corre con uvicorn (puerto 8000 por defecto en local).
#
# Si pruebas contra un backend LOCAL:
#   - En emulador Android: http://10.0.2.2:8000
#   - En celular fisico: usa la IP LAN de tu laptop
#     Ejemplo: http://192.168.1.100:8000
#     (Encuentra tu IP con `ipconfig` en Windows o `ip a` / `ifconfig` en Mac/Linux)
#
# Si pruebas contra el backend DESPLEGADO (Railway):
#   - https://vixxer-mensajero-backend.up.railway.app
EXPO_PUBLIC_API_URL=http://localhost:8000

# ---------- Socket.IO ----------
# URL del servidor Socket.IO (es la MISMA app que la API: mismo host y puerto).
# Si la dejas vacia, el cliente usa EXPO_PUBLIC_API_URL.
EXPO_PUBLIC_SOCKET_URL=http://localhost:8000

# ---------- Entorno ----------
# Valores: development | staging | production
EXPO_PUBLIC_ENV=development
