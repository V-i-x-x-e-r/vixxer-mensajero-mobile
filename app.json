{
  "expo": {
    "name": "Vixxer Mensajero",
    "slug": "vixxer-mensajero",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "vixxer",
    "splash": {
      "backgroundColor": "#0f1720"
    },
    "assetBundlePatterns": ["**/*"],
    "android": {
      "package": "dev.vixxer.mensajero",
      "adaptiveIcon": {
        "backgroundColor": "#0f1720"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-secure-store"]
  }
}
