{
  "expo": {
    "name": "Vixxer",
    "slug": "vixxer-mensajero",
    "scheme": "vixxer",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "dev.vixxer.mensajero",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_ADVERTISE",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#14110F",
        "foregroundImage": "./assets/adaptive-foreground.png"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-video",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "Vixxer usa la cámara para escanear códigos QR de amigos."
        }
      ],
      [
        "expo-media-library",
        {
          "savePhotosPermission": "Vixxer guarda las fotos que recibes en tu galería.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Vixxer usa el micrófono para grabar notas de voz."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "image": "./assets/splash-icon.png",
            "backgroundColor": "#0F0F0F"
          }
        }
      ],
      "react-native-ble-plx"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e796f5a3-5274-418a-bd51-d93a919b715b"
      }
    },
    "owner": "xecsarin"
  }
}
