# ============================================
# VIXXER MENSAJERO - MOBILE
# React Native + Expo gitignore
# ============================================

# ---------- Dependencies ----------
node_modules/
.pnp
.pnp.js
package-lock.json.bak

# ---------- Expo ----------
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts

# ---------- Native builds ----------
ios/
android/
*.orig.*

# Credenciales y firma de apps (NUNCA subir)
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.keystore
google-services.json
GoogleService-Info.plist

# ---------- Metro bundler ----------
.metro-health-check*
metro.config.js.bak

# ---------- Build outputs ----------
build/
*.apk
*.aab
*.ipa

# ---------- Testing ----------
coverage/
*.lcov
.nyc_output/

# ---------- Environment ----------
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# ---------- Logs ----------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# ---------- Editor ----------
.vscode/
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ---------- OS ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------- TypeScript ----------
*.tsbuildinfo

# ---------- EAS (Expo Application Services) ----------
.easignore.example

# ---------- Generados localmente ----------
secret/
keys/
tmp/
temp/
.cache/

# ---------- Misc ----------
*.pem
*.pem.pub# ============================================
